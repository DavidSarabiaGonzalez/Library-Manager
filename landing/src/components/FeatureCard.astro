---
interface Props {
  img: string;
  title: string;
  description: string;
  alt: string;
}

const { img, title, description, alt } = Astro.props;
---

<article class="p-7 w-105 h-70 border-gray-200">
  <img src={img} alt={alt} class="w-full h-auto rounded-lg" />
  <h4 class="font-bold text-2xl text-text-primary my-4">{title}</h4>
  <p class="text-text-secondary text-lg text-pretty">{description}</p>
</article>
